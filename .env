# Server Configuration
PORT=3000
JWT_SECRET=client-scope-secret-change-in-production

# OpenAI Configuration (optional - set this for AI-powered proposal generation)
# OPENAI_API_KEY=sk-your-openai-api-key

# Google OAuth Configuration (set this for Google Sign-In)
# Get your Client ID from https://console.cloud.google.com/apis/credentials
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SMTP Email Configuration - required for sending proposals via email
# Example for Gmail: host=smtp.gmail.com, port=587, secure=false
# You need to use an App Password (not your regular Gmail password)
# Get one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password